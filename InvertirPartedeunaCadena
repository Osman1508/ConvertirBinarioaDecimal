#include <iostream>
#include <string>
using namespace std;

int main()
{
    string texto;
    int a, b;

    cout<<"Ingrese una cadena: ";
    getline(cin, texto);

    cout<<"Ingrese indice inicial (a): ";
    cin>>a;

    cout<<"Ingrese indice final (b): ";
    cin>>b;

    int longitud = texto.length();

    if(b >= longitud)
    {
        b = longitud - 1;
    }

    if(a < 0)
    {
        a = 0;
    }

    while(a < b)
    {
        char temp = texto[a];
        texto[a] = texto[b];
        texto[b] = temp;

        a++;
        b--;
    }

    cout<<"\nResultado: "<<texto;
	cout<<("\n");
	system ("pause");
    return 0;
}
